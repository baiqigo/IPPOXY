{
    "choose_browser": "patchright",
    "email_suffix": "@hotmail.com",
    "proxy": "socks5://127.0.0.1:1080",
    "bot_protection_wait": 11,
    "max_captcha_retries": 2,
    "challenge_router": {
        "enabled": true,
        "order": [
            "microsoft_press",
            "visual_agent",
            "human_queue",
            "paid_captcha"
        ],
        "human_timeout_seconds": 0
    },
    "concurrent_flows": 1,
    "max_tasks": 1,
    "oauth2": {
        "enable_oauth2": false,
        "client_id": "",
        "redirect_url": "",
        "Scopes": [
            "offline_access",
            "https://graph.microsoft.com/Mail.ReadWrite",
            "https://graph.microsoft.com/Mail.Send",
            "https://graph.microsoft.com/User.Read"
        ]
    },
    "playwright": {
        "browser_path": ""
    },
    "patchright": {
        "browser_path": "/usr/bin/chromium"
    },
    "info": "外层参数必须填写,内部参数可选.email_suffix参数只能是@outlook.com或者@hotmail.com.playwright可用性较差.并且使用playwright指纹浏览器要能过https://www.browserscan.net,否则请使用patchright.请本地搭建代理池."
}
